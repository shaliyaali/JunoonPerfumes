              <span class="material-icons-outlined text-primary mr-2">badge</span>
              <h3 class="text-lg font-bold font-display tracking-tight">Personal Info</h3>
            </div>

            <div>
              <button type="button" id="editBtn"
                class="px-6 py-2 bg-primary text-black font-bold text-sm rounded uppercase tracking-wider">
                Edit
              </button>

              <button type="submit" id="saveBtn"
                class="px-6 py-2 bg-green-500 text-white font-bold text-sm rounded uppercase tracking-wider hidden">
                Save
              </button>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

            <div>
