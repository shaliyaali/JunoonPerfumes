        </a>
        <a class="flex items-center px-8 py-4 text-sm font-medium sidebar-active" href="#">
          <span class="material-icons-outlined mr-3">person</span>
          Profile Info
        </a>
        <a class="flex items-center px-8 py-4 text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800/50 transition"
          href="#">
          <span class="material-icons-outlined mr-3 text-gray-400">confirmation_number</span>
          My Coupons
        </a>
        <a class="flex items-center px-8 py-4 text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800/50 transition"
