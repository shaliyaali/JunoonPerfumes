              <!-- Display Mode -->
              <p id="nameText" class="text-base font-medium">
                <%= user.name %>
              </p>

              <!-- Edit Mode -->
              <input id="nameInput" name="name" type="text" value="<%= user.name %>"
                class="hidden w-full border px-3 py-2 rounded-md">
              <p class="text-red-500 text-xs mt-1 hidden" id="nameInputError"></p>
            </div>

            <div>
              <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-1 font-bold">Phone Number</p>

              <p id="phoneText" class="text-base font-medium">
                <%= user.phone ? user.phone : 'Not added' %>
              </p>

              <input id="phoneInput" name="phone" type="text" value="<%= user.phone %>"
                class="hidden w-full border px-3 py-2 rounded-md">
              <p class="text-red-500 text-xs mt-1 hidden" id="phoneInputError"></p>
            </div>

          </div>

        </form>
      </section>
      <section
        class="bg-card-light dark:bg-card-dark p-8 rounded-DEFAULT shadow-sm border border-gray-100 dark:border-gray-800">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div class="flex items-center">
            <span class="material-icons-outlined text-primary mr-2">alternate_email</span>
            <div>
              <h3 class="text-lg font-bold font-display tracking-tight">Email Settings</h3>
