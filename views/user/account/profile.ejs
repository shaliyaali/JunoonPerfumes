              <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
                <%= user.email %>
              </p>
            </div>
          </div>
          <% if (!user.googleId) { %>

            <button
              class="px-6 py-2 bg-transparent border-2 border-primary text-primary font-bold text-sm rounded uppercase tracking-wider hover:bg-primary hover:text-black transition"
              onclick="document.getElementById('email-input-group').classList.toggle('hidden')">
              Change Email
            </button>
        </div>

        <div class="hidden mt-8 pt-6 border-t border-gray-100 dark:border-gray-800 animate-fade-in"
          id="email-input-group">

          <form action="/edit-email" method="POST">
            <div class="max-w-md">

              <label class="block text-[10px] uppercase tracking-widest text-gray-400 mb-2 font-bold">
                New Email Address
              </label>

              <input
                class="w-full bg-gray-50 dark:bg-black border border-gray-200 dark:border-gray-700 rounded-md px-4 py-3 focus:ring-primary focus:border-primary transition mb-4"
                placeholder="Enter new email" type="email" name="newEmail" id="newemail" required />
              <p class="text-red-500 text-xs mt-1 hidden" id="newemailError"></p>

              <div class="flex space-x-3">

                <button type="submit"
                  class="px-4 py-2 bg-primary text-black font-bold text-sm rounded uppercase tracking-wider">
                  Save
                </button>

                <button type="button"
                  class="px-4 py-2 bg-gray-200 dark:bg-gray-800 text-gray-700 dark:text-gray-300 font-bold text-sm rounded uppercase tracking-wider"
                  onclick="document.getElementById('email-input-group').classList.add('hidden')">
                  Cancel
                </button>

              </div>

            </div>
          </form>

        </div>

        <% } else { %>

          <p class="mt-6 text-sm text-gray-500">
            Email cannot be changed for Google accounts.
          </p>

          <% } %>


            <% const isGoogleUser=!!user.googleId; %>
      </section>
      <section
        class="bg-card-light dark:bg-card-dark p-8 rounded-DEFAULT shadow-sm border border-gray-100 dark:border-gray-800">
        <div class="flex items-center mb-8">
          <span class="material-icons-outlined text-primary mr-2">lock</span>
          <h3 class="text-lg font-bold font-display tracking-tight">Change Password</h3>
        </div>
        <% if (isGoogleUser) { %>
          <div class="p-4 bg-gray-100 rounded text-sm text-gray-600">
            Password is managed by Google. You cannot change it here.
          </div>

          <% } else { %>
            <form class="space-y-6 max-w-xl" method="POST" action="/change-password">

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                <div class="relative md:col-span-2">
                  <label class="block text-[10px] uppercase tracking-widest text-gray-400 mb-2 font-bold">
                    Current Password
                  </label>
                  <div class="relative">
                    <input type="password" id="currentPassword" name="currentPassword" required
                      class="w-full bg-gray-50 border border-gray-200 rounded-md px-4 py-3 pr-10" />
                    <span class="material-icons-outlined absolute right-3 top-1/2 -translate-y-1/2 cursor-pointer text-gray-400 select-none"
                      onclick="togglePassword('currentPassword', this)">visibility</span>
                  </div>
                  <p class="text-red-500 text-xs mt-1 hidden" id="currentpasswordError"></p>
                </div>

                <div class="relative">
                  <label class="block text-[10px] uppercase tracking-widest text-gray-400 mb-2 font-bold">
                    New Password
                  </label>
                  <div class="relative">
                    <input type="password" name="newPassword" id="newPassword" required minlength="8"
                      class="w-full bg-gray-50 border border-gray-200 rounded-md px-4 py-3 pr-10" />
                    <span class="material-icons-outlined absolute right-3 top-1/2 -translate-y-1/2 cursor-pointer text-gray-400 select-none"
                      onclick="togglePassword('newPassword', this)">visibility</span>
                  </div>
                  <p class="text-red-500 text-xs mt-1 hidden" id="newpasswordError"></p>
                </div>

                <div class="relative">
                  <label class="block text-[10px] uppercase tracking-widest text-gray-400 mb-2 font-bold">
                    Confirm New Password
                  </label>
                  <div class="relative">
                    <input type="password" name="confirmPassword" id="confirmPassword" required
                      class="w-full bg-gray-50 border border-gray-200 rounded-md px-4 py-3 pr-10" />
                    <span class="material-icons-outlined absolute right-3 top-1/2 -translate-y-1/2 cursor-pointer text-gray-400 select-none"
                      onclick="togglePassword('confirmPassword', this)">visibility</span>
                  </div>
                  <p class="text-red-500 text-xs mt-1 hidden" id="confirmPasswordError"></p>
                </div>

              </div>

              <button type="submit"
                class="px-6 py-3 bg-primary text-black font-bold text-sm rounded uppercase tracking-wider">
                Update Password
              </button>

            </form>
            <% } %>
      </section>


      <section
        class="bg-card-light dark:bg-card-dark p-8 rounded-DEFAULT shadow-sm border border-gray-100 dark:border-gray-800">
        <div class="flex items-center mb-8">
          <span class="material-icons-outlined text-primary mr-2">place</span>
          <a href="/manageaddress" class="text-lg font-bold font-display tracking-tight underline">Manage Addresses</a>
        </div>

      </section>
    
   

