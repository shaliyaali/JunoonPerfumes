    </main>
  </div>
  <button
    class="fixed bottom-6 right-6 w-12 h-12 bg-black dark:bg-white text-white dark:text-black rounded-full shadow-2xl flex items-center justify-center z-[100] transition-transform active:scale-95"
    onclick="document.documentElement.classList.toggle('dark')">
    <span class="material-icons-outlined">dark_mode</span>
  </button>

