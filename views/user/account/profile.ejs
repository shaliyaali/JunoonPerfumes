      </div>
      <div>
        <h1 class="font-display text-xl tracking-widest font-bold">JUNOON</h1>
        <p class="text-[10px] tracking-[0.2em] uppercase opacity-70">Perfumes</p>
      </div>
    </div>
    <nav class="hidden md:flex space-x-8 text-xs font-semibold tracking-widest uppercase">
