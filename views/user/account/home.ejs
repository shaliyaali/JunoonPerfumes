<% if (session && session.user) { %>

  <!-- Avatar --> 
  <a href="/profile"
     class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold uppercase">
     

    <%= session.user.name.charAt(0) %>

