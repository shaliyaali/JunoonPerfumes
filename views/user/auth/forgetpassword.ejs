<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Forgot Password - Junoon Perfumes</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&amp;family=Manrope:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
<style type="text/tailwindcss">
        :root {
            --bg-dark: #1A1A1A;
            --gold-accent: #D4AF37;
            --gold-soft: #E3C57A;
        }
        body {
            font-family: 'Manrope', sans-serif;
            background-color: var(--bg-dark);
        }
        .serif-heading {
            font-family: 'Playfair Display', serif;
        }
    </style>
<script id="tailwind-config">
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        gold: {
                            DEFAULT: '#E3C57A',
                            hover: '#D4AF37',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-6">
   <input type="text" id="message" value="<%= message %>" name="message" hidden>
<div class="w-full max-w-[480px] flex flex-col items-center">
<div class="mb-10 flex flex-col items-center gap-3">
<!-- <div class="size-12 text-gold">
<svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
<path clip-rule="evenodd" d="M24 4H42V17.3333V30.6667H24V44H6V30.6667V17.3333H24V44Z" fill="currentColor" fill-rule="evenodd" opacity="0.2"></path>
<path d="M24 4L24 44M6 17.3333H42M6 30.6667H42" stroke="currentColor" stroke-linecap="round" stroke-width="2"></path>
</svg>
</div>
<h1 class="text-white text-lg font-bold tracking-[0.25em] uppercase">Junoon Perfumes</h1> -->
</div>
<div class="w-full bg-white rounded-[24px] p-8 md:p-12 shadow-2xl">
<div class="flex flex-col">
<h2 class="serif-heading text-[#1A1A1A] text-3xl md:text-4xl font-bold mb-3 text-center">Forgot Password</h2>
<p class="text-gray-500 text-center text-sm md:text-base font-normal leading-relaxed mb-10">
                    Enter your email to receive a reset link.
                </p>
<form class="flex flex-col gap-6" method="POST" action="/forget-password" id="forget-password" >
<div class="flex flex-col gap-2">
<label class="text-[#1A1A1A] text-xs font-bold uppercase tracking-wide ml-1" for="email">Email ID</label>
<input class="w-full bg-[#F8F8F8] border-none rounded-xl py-4 px-5 text-[#1A1A1A] placeholder:text-gray-400 focus:ring-2 focus:ring-gold/50 transition-all duration-300" id="email" name="email" placeholder="email@example.com" type="email"/>
</div>
<div class="flex flex-col gap-8 mt-2">
<button type="submit" class="w-full bg-gold hover:bg-gold-hover text-white font-bold text-sm py-5 rounded-xl tracking-widest uppercase transition-all duration-300 shadow-md">
                            SEND RESET OTP
                        </button >
<a class="flex items-center justify-center gap-2 text-gray-400 hover:text-gold transition-colors duration-300 text-sm font-medium" href="/signin">
<span class="material-symbols-outlined text-base">west</span>
<span>Back to Log In</span>
</a>
</div>
</form>
</div>
</div>
<div class="mt-12 text-center">
<p class="text-gray-600 text-[10px] tracking-widest uppercase">
                © 2024 Junoon Perfumes. All Rights Reserved.
            </p>
<div class="flex gap-6 mt-4 justify-center">
<a class="text-gray-600 hover:text-gold text-[10px] uppercase tracking-widest transition-colors" href="#">Privacy Policy</a>
<a class="text-gray-600 hover:text-gold text-[10px] uppercase tracking-widest transition-colors" href="#">Support</a>
</div>
</div>
</div>

</body>
<script>
    const message=document.getElementById('message').value
    if(message){
        swal.fire(message)
    }


</script>

</html>