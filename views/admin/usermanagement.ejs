<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Junoon Admin - User Management</title>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&amp;family=Inter:wght@300;400;500;600&amp;family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
<script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#D4AF37", // Gold
                        secondary: "#1A1A1A", // Luxury Black
                        "background-light": "#F9F8F3", // Ivory Light
                        "background-dark": "#121212", // Dark Mode Surface
                    },
                    fontFamily: {
                        display: ["Playfair Display", "serif"],
                        sans: ["Inter", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "4px",
                    },
                },
            },
        };
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
            font-size: 20px;
        }
        .sidebar-link.active {
            background-color: #D4AF37;
            color: white;
        }
        body {
            font-family: 'Inter', sans-serif;
        }
        h1, h2, .font-display {
            font-family: 'Playfair Display', serif;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-800 dark:text-slate-200 min-h-screen flex">
<aside class="w-64 border-r border-slate-200 dark:border-slate-800 flex flex-col fixed h-screen bg-white dark:bg-zinc-900 z-10">
<div class="p-8">
<div class="flex items-center gap-3">
<div class="w-10 h-10 bg-primary flex items-center justify-center rounded">
<span class="material-symbols-outlined text-white">temp_preferences_custom</span>
</div>
<div>
<h2 class="text-xl font-display font-bold text-secondary dark:text-white leading-none">Junoon</h2>
<p class="text-[10px] uppercase tracking-widest text-slate-400 font-medium">Admin Suite</p>
</div>
</div>
</div>
<nav class="flex-1 px-4 space-y-1">
<a class="sidebar-link flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors" href="/admin/dashboard">
<span class="material-symbols-outlined">dashboard</span>
<span class="text-sm font-medium">Dashboard</span>
</a>
<a class="sidebar-link flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors" href="/admin/products">
<span class="material-symbols-outlined">inventory_2</span>
<span class="text-sm font-medium">Products</span>
</a>
<a class="sidebar-link flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors" href="/admin/categories">
<span class="material-symbols-outlined">category</span>
<span class="text-sm font-medium">Categories</span>
</a>
<a class="sidebar-link flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors" href="/admin/orders">
<span class="material-symbols-outlined">shopping_cart</span>
<span class="text-sm font-medium">Orders</span>
</a>
<a class="sidebar-link active flex items-center gap-3 px-4 py-3 rounded transition-colors" href="/admin/usermanagement">
<span class="material-symbols-outlined">group</span>
<span class="text-sm font-medium">Users</span>
</a>
<a class="sidebar-link flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors" href="/admin/sales">
<span class="material-symbols-outlined">query_stats</span>
<span class="text-sm font-medium">Sales &amp; Revenue</span>
</a>
</nav>
<div class="p-4 border-t border-slate-100 dark:border-slate-800">
<a class="flex items-center gap-3 px-4 py-3 text-slate-500 dark:text-slate-400 hover:text-red-600 transition-colors" href="/admin/logout">
<span class="material-symbols-outlined">logout</span>
<span class="text-sm font-medium">Logout</span>
</a>
</div>
</aside>
<main class="flex-1 ml-64 min-w-0">
<header class="h-16 border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-zinc-900/80 backdrop-blur-md sticky top-0 z-20 px-8 flex items-center">
<form action="/admin/usermanagement" method="GET" class="flex items-center w-full max-w-xl text-slate-400 bg-slate-50 dark:bg-zinc-800 px-4 py-2 rounded-md border border-slate-100 dark:border-slate-700">
    <span class="material-symbols-outlined mr-2 scale-90">search</span>
    <input name="search" value="<%= search %>" class="bg-transparent border-none focus:ring-0 text-sm w-full placeholder:text-slate-400 dark:text-slate-200" placeholder="Search users by name or email..." type="text"/>
</form>
<div class="ml-auto flex items-center gap-4">
<!-- <button class="p-2 text-slate-500 hover:bg-slate-100 dark:hover:bg-zinc-800 rounded-full transition-colors" onclick="document.documentElement.classList.toggle('dark')">
<span class="material-symbols-outlined dark:hidden">dark_mode</span>
<span class="material-symbols-outlined hidden dark:block">light_mode</span>
</button> -->
<!-- <div class="w-8 h-8 rounded-full bg-slate-200 dark:bg-zinc-700 flex items-center justify-center overflow-hidden">
<img alt="Admin Avatar" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAyBbYdWU6_A45OOdX6GjtevalLh8avB1GQiqGiTHfRHw4tjWciQ1xLBoWaB6QyIQM2a1OH9aVNGBuOWpIbcdgdQx_blR_lIC7x2mDNON6CSsnJyl5m85R1_oqrZhG2b5gZl0C2OiI03-nNZQREnlqpFnZ37gNwj-Rej3BNo9z2vuanJPshOp-hOvsBZDBbdmwBjfT705xbuilvvcfUgbvObztRACHIhDCwOg_1gLpFSHhLw5mTDqLBcouOfgzlTEQf2HnnqWtzU9w"/>
</div> -->
</div>
</header>
<div class="max-w-[1550px] mx-auto p-8 lg:p-12">
<div class="mb-10">
<h1 class="text-4xl font-display font-bold text-secondary dark:text-white mb-2 tracking-tight">User Management</h1>

</div>
<div class="flex gap-4 mb-8">
    <a href="/admin/usermanagement?status=all&search=<%= search %>" 
       class="px-6 py-2 text-sm font-medium transition-colors <% if (status === 'all') { %>bg-secondary dark:bg-white text-white dark:text-secondary<% } else { %>bg-white dark:bg-zinc-900 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 hover:border-primary<% } %>">
        All Users 
        <% if (status === 'all') { %>
            <span class="ml-2 opacity-50 text-xs"><%= userCount %></span>
        <% } %>
    </a>
    <a href="/admin/usermanagement?status=active&search=<%= search %>" 
       class="px-6 py-2 text-sm font-medium transition-colors <% if (status === 'active') { %>bg-secondary dark:bg-white text-white dark:text-secondary<% } else { %>bg-white dark:bg-zinc-900 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 hover:border-primary<% } %>">
        Active Users
        <% if (status === 'active') { %>
            <span class="ml-2 opacity-50 text-xs"><%= userCount %></span>
        <% } %>
    </a>
    <a href="/admin/usermanagement?status=blocked&search=<%= search %>" 
       class="px-6 py-2 text-sm font-medium transition-colors <% if (status === 'blocked') { %>bg-secondary dark:bg-white text-white dark:text-secondary<% } else { %>bg-white dark:bg-zinc-900 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 hover:border-primary<% } %>">
        Blocked
        <% if (status === 'blocked') { %>
            <span class="ml-2 opacity-50 text-xs"><%= userCount %></span>
        <% } %>
    </a>
</div>
<div class="bg-white dark:bg-zinc-900 border border-slate-100 dark:border-slate-800 shadow-sm overflow-hidden">
<table class="w-full text-left border-collapse">
<thead>
<tr class="bg-slate-50/50 dark:bg-zinc-800/50 border-b border-slate-100 dark:border-slate-800">
<th class="px-8 py-4 text-[11px] font-bold uppercase tracking-widest text-slate-400">User</th>
<th class="px-8 py-4 text-[11px] font-bold uppercase tracking-widest text-slate-400">Status</th>
<!-- <th class="px-8 py-4 text-[11px] font-bold uppercase tracking-widest text-slate-400">Joined Date</th> -->
<th class="px-8 py-4 text-[11px] font-bold uppercase tracking-widest text-slate-400 text-right">Actions</th>
</tr>
</thead>
<tbody class="divide-y divide-slate-100 dark:divide-slate-800">
    <% if (users && users.length > 0) { %>
        <% users.forEach(user => { %>
            <tr class="group hover:bg-slate-50/50 dark:hover:bg-zinc-800/30 transition-colors">
                <td class="px-8 py-6">
                    <div class="flex flex-col">
                        <span class="text-sm font-semibold text-secondary dark:text-white"><%= user.name %></span>
                        <span class="text-xs text-slate-400"><%= user.email %></span>
                    </div>
                </td>
                <td class="px-8 py-6">
                    <% if (user.isBlocked) { %>
                        <div class="flex items-center gap-2">
                            <span class="w-1.5 h-1.5 rounded-full bg-orange-400"></span>
                            <span class="text-xs font-semibold text-orange-500 dark:text-orange-400">Blocked</span>
                        </div>
                    <% } else { %>
                        <div class="flex items-center gap-2">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                            <span class="text-xs font-semibold text-emerald-600 dark:text-emerald-400">Active</span>
                        </div>
                    <% } %>
                </td>
                <!-- <td class="px-8 py-6 text-sm text-slate-500 dark:text-slate-400">
                    <%= user.createdAt ? new Date(user.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'N/A' %>
                </td> -->
                <td class="px-8 py-6 text-right">
                    <div class="flex justify-end gap-6 items-center">
                        <% if (user.isBlocked) { %>
                            <a href="/admin/unblock-customer?id=<%= user._id %>" onclick="return confirm('Are you sure you want to unblock <%= user.name %>?')" class="text-[11px] font-bold uppercase tracking-widest text-primary hover:opacity-80 transition-opacity">Unblock</a>
                        <% } else { %>
                            <a href="/admin/block-customer?id=<%= user._id %>" onclick="return confirm('Are you sure you want to block <%= user.name %>?')" class="text-[11px] font-bold uppercase tracking-widest text-primary hover:opacity-80 transition-opacity">Block</a>
                        <% } %>
                    </div>
                </td>
            </tr>
        <% }) %>
    <% } else { %>
        <tr>
            <td colspan="4" class="text-center py-10 px-8 text-slate-500 dark:text-slate-400">
                No users found.
            </td>
        </tr>
    <% } %>
</tbody>
</table>
</div>
<div class="mt-8 flex justify-center items-center gap-6">
    <% if (totalPages > 1) { %>
        <% for(let i = 1; i <= totalPages; i++) { %>
            <a href="/admin/usermanagement?page=<%= i %>&search=<%= search %>&status=<%= status %>" 
               class="text-xs font-bold tracking-widest pb-1 transition-colors 
                      <% if (i === currentPage) { %>
                          border-b-2 border-primary text-secondary dark:text-white
                      <% } else { %>
                          text-slate-400 hover:text-secondary dark:hover:text-white border-b-2 border-transparent
                      <% } %>">
                <%= i.toString().padStart(2, '0') %>
            </a>
        <% } %>
    <% } %>
</div>
</div>
</main>

</body></html>